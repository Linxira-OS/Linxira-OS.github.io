    .nav-links { display: flex; gap: 1.5rem; align-items: center; }
    .nav-links a { color: #94a3b8; text-decoration: none; font-size: 0.9rem; }
    .nav-links a:hover { color: #14b8a6; }
    .lang-link { background: rgba(51,65,85,0.5); border: 1px solid rgba(51,65,85,0.5); color: #e2e8f0; padding: 0.4rem 0.8rem; border-radius: 6px; text-decoration: none; font-size: 0.85rem; }

    .layout { display: flex; padding-top: 60px; min-height: 100vh; }
    .sidebar { width: 260px; background: #0c1322; border-right: 1px solid rgba(51,65,85,0.3); padding: 2rem 0; position: fixed; top: 60px; bottom: 0; overflow-y: auto; }
    .sidebar-title { color: #64748b; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; padding: 0 1.5rem; margin-bottom: 0.5rem; }
    .sidebar a { display: block; padding: 0.5rem 1.5rem; color: #94a3b8; text-decoration: none; font-size: 0.9rem; transition: all 0.2s; border-left: 3px solid transparent; }
    .sidebar a:hover { color: #14b8a6; background: rgba(20,184,166,0.05); }
    .sidebar a.active { color: #14b8a6; border-left-color: #14b8a6; background: rgba(20,184,166,0.08); }
    .sidebar .section { margin-bottom: 1.5rem; }

    .main { flex: 1; margin-left: 260px; padding: 3rem 4rem; max-width: 900px; }
    h1 { font-size: 2.2rem; font-weight: 700; margin-bottom: 1rem; background: linear-gradient(135deg, #14b8a6, #6366f1); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    h2 { font-size: 1.4rem; color: #e2e8f0; margin: 2rem 0 0.8rem; padding-top: 1rem; border-top: 1px solid rgba(51,65,85,0.3); }
    p { color: #94a3b8; margin-bottom: 1rem; }
    a { color: #14b8a6; }
    .doc-card { display: block; background: linear-gradient(135deg, rgba(30,41,59,0.6), rgba(15,23,42,0.8)); border: 1px solid rgba(51,65,85,0.5); border-radius: 12px; padding: 1.5rem; margin: 1rem 0; text-decoration: none; transition: border-color 0.3s; }
    .doc-card:hover { border-color: rgba(20,184,166,0.4); }
    .doc-card h3 { color: #14b8a6; margin-bottom: 0.3rem; font-size: 1.1rem; }
    .doc-card p { font-size: 0.9rem; margin: 0; color: #94a3b8; }
    .keyword { display: inline-block; font-size: 0.7rem; background: rgba(20,184,166,0.15); color: #14b8a6; padding: 0.15rem 0.5rem; border-radius: 4px; margin: 0.2rem; }
    footer { text-align: center; padding: 3rem 2rem; color: #475569; font-size: 0.85rem; border-top: 1px solid rgba(51,65,85,0.3); margin-left: 260px; }
    @media (max-width: 768px) { .sidebar { display: none; } .main { margin-left: 0; padding: 2rem; } footer { margin-left: 0; } }
  </style>
