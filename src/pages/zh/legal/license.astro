      <li><a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" style="color:#14b8a6;">CC BY-NC-SA 4.0</a></li>
      <li><a href="https://www.gnu.org/licenses/old-licenses/gpl-2.0.html" style="color:#14b8a6;">GNU GPL v2.0</a></li>
    </ul>
